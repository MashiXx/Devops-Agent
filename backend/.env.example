# ── Server config ────────────────────────────────────────────────
PORT=3001

# ── AI Provider ─────────────────────────────────────────────────
# Chọn provider: "anthropic" hoặc "gemini" (mặc định: anthropic)
AI_PROVIDER=anthropic

# ── Anthropic API ────────────────────────────────────────────────
# Lấy tại: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Gemini API ────────────────────────────────────────────
# Lấy tại: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── SSH Default credentials (tuỳ chọn) ──────────────────────────
# Nếu không set thì user tự nhập trong UI
# DEFAULT_SSH_KEY_PATH=/home/youruser/.ssh/id_rsa
# DEFAULT_SSH_PASSPHRASE=
